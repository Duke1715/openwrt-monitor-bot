#!/bin/sh /etc/rc.common
# OpenWrt procd init script for wrt-monitor-bot

START=99
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /bin/sh /usr/local/bin/wrt-monitor-bot.sh
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
